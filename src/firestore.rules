rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPlatformAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function membershipDoc(communityId) {
      return get(/databases/$(database)/documents/communityMembers/$(communityId + '_' + request.auth.uid));
    }

    function isCommunityMember(communityId) {
      return isSignedIn() && exists(/databases/$(database)/documents/communityMembers/$(communityId + '_' + request.auth.uid));
    }

    function isCommunityManager(communityId) {
      return isPlatformAdmin() || (
        isCommunityMember(communityId) &&
        membershipDoc(communityId).data.role in ['owner', 'admin']
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isCommunityManager(communityId);
      allow delete: if isPlatformAdmin();
    }

    match /communityMembers/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isSignedIn();
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isCommunityMember(request.resource.data.communityId);
      allow update, delete: if isSignedIn() && (
        isCommunityManager(resource.data.communityId) ||
        resource.data.authorId == request.auth.uid
      );
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isCommunityMember(request.resource.data.communityId);
      allow update: if false;
      allow delete: if isSignedIn() && (
        isCommunityManager(resource.data.communityId) ||
        resource.data.authorId == request.auth.uid
      );
    }
  }
}
